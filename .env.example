# Audit Agent Configuration

# Server URL for uploading audit records
AUDIT_SERVER_URL=http://localhost:8080

# Local SQLite database path for agent
AUDIT_DB_PATH=./data/audit-agent.db

# Shell to use (empty for auto-detect, defaults to /bin/bash)
AUDIT_SHELL=

# Batch upload threshold - number of records to trigger upload
AUDIT_COUNT_THRESHOLD=20

# Batch upload threshold - time duration to trigger upload
AUDIT_TIME_THRESHOLD=5s

# Input buffer size for reading from stdin
AUDIT_INPUT_BUFFER=4096

# Log file path (optional, defaults to same directory as db path)
# AUDIT_LOG_FILE=./data/agent.log
